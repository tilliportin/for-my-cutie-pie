<!DOCTYPE html>
<html lang="fi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sydän</title>

<style>
body{
    margin:0;
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background:#fff7fa;
    overflow:hidden;
    font-family:Georgia, serif;
}

.heart-wrapper{
    position:relative;
}

.heart{
    position:relative;
    width:320px;
    height:320px;
    background:linear-gradient(145deg,#ff8fc7,#ff69b4);
    transform:rotate(-45deg);
    border:4px solid #ffd6ea;
    box-shadow:
        0 0 25px rgba(255,105,180,0.35),
        inset 0 0 20px rgba(255,255,255,0.25);
    animation:glow 4s ease-in-out infinite;
}

.heart::before,
.heart::after{
    content:"";
    position:absolute;
    width:320px;
    height:320px;
    background:linear-gradient(145deg,#ff8fc7,#ff69b4);
    border:4px solid #ffd6ea;
    border-radius:50%;
}

.heart::before{
    top:-160px;
    left:0;
}

.heart::after{
    left:160px;
    top:0;
}

.text{
    position:absolute;
    top:50%;
    left:50%;
    width:70%;
    text-align:center;
    color:white;
    font-size:26px;
    line-height:1.4;
    font-weight:bold;
    text-shadow:0 1px 3px rgba(0,0,0,0.25);
    transform:translate(-50%,-50%) rotate(45deg);
    z-index:10;
}

/* Hienovaraiset tähdet */
.sparkle{
    position:absolute;
    color:white;
    font-size:18px;
    opacity:0;
    animation:twinkle 4s infinite;
}

.s1{top:-20px;left:40px;animation-delay:0s;}
.s2{top:30px;right:-15px;animation-delay:1s;}
.s3{bottom:40px;left:-15px;animation-delay:2s;}
.s4{bottom:-15px;right:60px;animation-delay:3s;}

@keyframes twinkle{
    0%,100%{
        opacity:0;
        transform:scale(0.5);
    }
    50%{
        opacity:1;
        transform:scale(1.2);
    }
}

@keyframes glow{
    0%,100%{
        box-shadow:
            0 0 20px rgba(255,105,180,0.25),
            inset 0 0 20px rgba(255,255,255,0.2);
    }
    50%{
        box-shadow:
            0 0 35px rgba(255,105,180,0.45),
            inset 0 0 30px rgba(255,255,255,0.35);
    }
}
</style>
</head>
<body>

<div class="heart-wrapper">

    <div class="sparkle s1">✦</div>
    <div class="sparkle s2">✧</div>
    <div class="sparkle s3">✦</div>
    <div class="sparkle s4">✧</div>

    <div class="heart">
        <div class="text">
            Tähän tulee lauseesi
        </div>
    </div>

</div>

</body>
</html>
